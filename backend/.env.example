# LLM Provider Configuration
# Set to "gemini" to use the Gemini API, or "mock" for canned responses (default).
LLM_PROVIDER=mock

# Gemini API key — required when LLM_PROVIDER=gemini
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Timeout in seconds for LLM API calls (default: 60)
LLM_TIMEOUT_SEC=60
